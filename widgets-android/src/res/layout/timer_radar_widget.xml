<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/timer_radar_widget_background"
  android:orientation="vertical"
  android:padding="14dp">

  <TextView
    android:id="@+id/widget_phase"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:ellipsize="end"
    android:maxLines="1"
    android:text="Time Radar"
    android:textAllCaps="true"
    android:textColor="#687076"
    android:textSize="11sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_title"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="4dp"
    android:layout_weight="1"
    android:ellipsize="end"
    android:maxLines="2"
    android:text="Start a focus session"
    android:textColor="#27211C"
    android:textSize="14sp"
    android:textStyle="bold" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/widget_time"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:includeFontPadding="false"
      android:text="--:--"
      android:textColor="#F47E61"
      android:textSize="28sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_status"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:background="@drawable/timer_radar_widget_status_background"
      android:paddingHorizontal="8dp"
      android:paddingVertical="4dp"
      android:text="READY"
      android:textColor="#687076"
      android:textSize="10sp"
      android:textStyle="bold" />
  </LinearLayout>

  <ProgressBar
    android:id="@+id/widget_progress"
    style="?android:attr/progressBarStyleHorizontal"
    android:layout_width="match_parent"
    android:layout_height="4dp"
    android:layout_marginTop="8dp"
    android:indeterminate="false"
    android:max="100"
    android:progress="0"
    android:visibility="gone" />
</LinearLayout>
