{
  "name": "time-radar",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "postinstall": "node scripts/patch-react-native-gradle-plugin.js && node scripts/patch-expo-modules-jsi-swift-runtime.js && node scripts/patch-expo-widgets-ios-version.js",
    "test": "rm -rf .test-build && tsc -p tsconfig.test.json && node --test test/*.test.cjs"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/ui": "~56.0.17",
    "@tabler/icons-react-native": "^3.44.0",
    "expo": "^56.0.11",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.6",
    "expo-haptics": "~56.0.3",
    "expo-iap": "^4.3.1",
    "expo-image": "~56.0.11",
    "expo-keep-awake": "~56.0.3",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.17",
    "expo-router": "~56.2.10",
    "expo-screen-orientation": "~56.0.5",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-widgets": "~56.0.18",
    "i18n-js": "^4.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@types/react": "~19.2.14",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "fs-extra": "^11.3.5",
    "typescript": "~6.0.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-modules-jsi"
        ]
      }
    },
    "autolinking": {
      "android": {
        "exclude": [
          "expo-widgets"
        ]
      }
    }
  },
  "private": true
}
